# Firebase project ID (found in Firebase Console → Project settings)
FIREBASE_PROJECT_ID=techyuva-19645

# Service account client email (ends with @<project>.iam.gserviceaccount.com)
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@techyuva-19645.iam.gserviceaccount.com

# Service account private key — paste the full key including BEGIN/END lines.
# Vercel will preserve newlines; if they become \n the backend normalizes them.
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEvQIBADANBgkqhkiG9w0BAQEFAASCBKcwggSjAgEAAoIBAQC...\n-----END PRIVATE KEY-----\n"

# Optional: local development path to Firebase service account JSON file
# This file is gitignored and should NOT be committed.
FIREBASE_SERVICE_ACCOUNT_PATH=./backend/firebase-key.json

# Optional: full service account JSON as a single env var (alternative to the three vars above)
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
